# ============================================================
# ton-llm-key — Environment Variables
# §10 HANDOFF.md
# ============================================================
# Copy to .env.local for local dev. Never commit .env.local.

# ---- LiteLLM (§1 D5) ----
LITELLM_BASE_URL=https://api2.ai.tokamak.network
LITELLM_MASTER_KEY=sk-...

# ---- Ethereum RPC (§2) ----
# Alchemy or Infura mainnet endpoint (free tier sufficient)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>
# Optional: Sepolia testnet for development
RPC_URL_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>

# ---- Upstash Redis (§1 D9) ----
# Vercel KV was discontinued Dec 2024 → connect Upstash Redis via Vercel Marketplace for auto-injection.
# How to connect: Vercel Dashboard → Storage → Connect Store → Upstash Redis (Marketplace)
# Local dev: run vercel env pull .env.local to sync automatically
KV_REST_API_URL=...
KV_REST_API_TOKEN=...
KV_REST_API_READ_ONLY_TOKEN=...

# ---- Session (§1 D4) ----
# Generate with: openssl rand -base64 32
SESSION_SECRET=<openssl rand -base64 32>

# ---- Staking threshold (§1 D2) ----
# Server-side eligibility check (API route)
# dev / testing  → .env.local:      MIN_TON=10
# production     → .env.production: MIN_TON=200
MIN_TON=10

# Client-side display (landing page, dashboard)
# Must match MIN_TON for the same environment
NEXT_PUBLIC_MIN_TON=10

# ---- Purchase access (§4-2) ----
# Treasury wallet that receives the 5 TON ERC-20 payment
TREASURY_ADDRESS=0x...
# Also expose for frontend ERC-20 transfer target
NEXT_PUBLIC_TREASURY_ADDRESS=0x...
# TON ERC-20 contract address on Ethereum L1
TON_ERC20_ADDRESS=0x2be5e8c109e2197D077D13A82dAead6a9b3433C5
# Price in TON (default 5); server-side
PURCHASE_PRICE_TON=5
# Client-side display
NEXT_PUBLIC_PURCHASE_PRICE_TON=5

# ---- SIWE Domain (§4 security: domain spoofing prevention) ----
# Trusted domain for SIWE signature verification. Host header used only as fallback.
# dev / testing  → localhost:3000
# production     → your actual domain (e.g. app.example.com)
APP_DOMAIN=localhost:3000
